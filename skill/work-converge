#!/usr/bin/env python3
"""
work-converge — parse reviewer XML responses, compute lineage-weighted quorum.

Reads each <agent>-findings.md from <out-dir>, extracts the <findings> block
(reviewers may wrap it in chatter — we tolerate that), classifies each verdict,
and decides whether quorum is reached.

Quorum rule (lineage-weighted):
  agree if >=1 agent of each ENABLED lineage returned <verdict agree="true">.
  Partial verdicts count as agree only if reasoning explicitly says minor-only.

Exit codes:
  0  -> quorum reached, proceed
  1  -> quorum NOT reached (revise + retry recommended)
  2  -> too many missing/dead reviewers to decide (escalate to user)

Output: JSON to stdout with full breakdown.
"""

import argparse
import json
import re
import sys
from pathlib import Path
from xml.etree import ElementTree as ET


def load_agent_types(agents_json: Path) -> dict[str, str]:
    """name -> type from agents.json."""
    data = json.loads(agents_json.read_text())
    return {a["name"]: a["type"] for a in data["agents"]}


def disabled_lineages(agents_json: Path) -> set[str]:
    """Lineages where every configured agent is marked disabled."""
    data = json.loads(agents_json.read_text())
    by_lin: dict[str, list[bool]] = {}
    for a in data["agents"]:
        by_lin.setdefault(a["type"], []).append(bool(a.get("disabled", False)))
    return {lin for lin, flags in by_lin.items() if flags and all(flags)}


# Reviewers may wrap their XML in markdown chatter; pull just the <findings> block.
FINDINGS_RE = re.compile(r"<findings>.*?</findings>", re.DOTALL | re.IGNORECASE)
VERDICT_RE = re.compile(
    r'<verdict\s+agree="(true|false|partial)"\s*>(.*?)</verdict>',
    re.DOTALL | re.IGNORECASE,
)
FINDING_RE = re.compile(
    r'<finding\s+severity="(critical|high|medium|low)"\s+category="([^"]+)"\s*>(.*?)</finding>',
    re.DOTALL | re.IGNORECASE,
)
DONE_RE = re.compile(r"^##\s*DONE\s*$", re.MULTILINE)


def extract_response(text: str) -> dict:
    """Pull verdict + findings out of one reviewer's file. Tolerant of wrapper text."""
    block_match = FINDINGS_RE.search(text)
    block = block_match.group(0) if block_match else text  # fall back to whole text

    # Try strict XML first; fall back to regex if reviewer's XML is malformed.
    findings = []
    verdict = None
    verdict_reason = ""

    def _structured_evidence(elem) -> dict:
        """Extract <evidence> in either old (text) or new (file-path/line-number/quoted-line) shape."""
        if elem is None:
            return {"file_path": "", "line_number": None, "quoted_line": "", "raw": ""}
        # New structured shape
        fp = elem.findtext("file-path") or ""
        ln = elem.findtext("line-number") or ""
        ql = elem.findtext("quoted-line") or ""
        if fp.strip() or ql.strip():
            try:
                ln_int = int(ln.strip()) if ln.strip() else None
            except ValueError:
                ln_int = None
            return {
                "file_path": fp.strip(),
                "line_number": ln_int,
                "quoted_line": ql.strip("\n"),
                "raw": "",
            }
        # Legacy text-only evidence
        return {"file_path": "", "line_number": None, "quoted_line": "", "raw": (elem.text or "").strip()}

    try:
        root = ET.fromstring(block)
        for f in root.findall("finding"):
            ev = _structured_evidence(f.find("evidence"))
            findings.append({
                "severity": (f.get("severity") or "medium").lower(),
                "category": (f.get("category") or "other").lower(),
                "claim": (f.findtext("claim") or "").strip(),
                "evidence": ev,
                "suggestion": (f.findtext("suggestion") or "").strip(),
            })
        v = root.find("verdict")
        if v is not None:
            verdict = (v.get("agree") or "").lower() or None
            verdict_reason = (v.findtext("reasoning") or "").strip()
    except ET.ParseError:
        # Regex fallback (legacy reviewers using old flat-text evidence)
        for m in FINDING_RE.finditer(block):
            sev, cat, body = m.groups()
            claim_m = re.search(r"<claim>(.*?)</claim>", body, re.DOTALL)
            evid_m = re.search(r"<evidence>(.*?)</evidence>", body, re.DOTALL)
            sugg_m = re.search(r"<suggestion>(.*?)</suggestion>", body, re.DOTALL)
            evid_raw = (evid_m.group(1).strip() if evid_m else "")
            # Try to pull structured sub-fields out of the regex'd evidence too
            fp_m = re.search(r"<file-path>(.*?)</file-path>", evid_raw, re.DOTALL)
            ln_m = re.search(r"<line-number>(.*?)</line-number>", evid_raw, re.DOTALL)
            ql_m = re.search(r"<quoted-line>(?:<!\[CDATA\[)?(.*?)(?:\]\]>)?</quoted-line>", evid_raw, re.DOTALL)
            try:
                ln_int = int(ln_m.group(1).strip()) if ln_m else None
            except ValueError:
                ln_int = None
            evidence = {
                "file_path": (fp_m.group(1).strip() if fp_m else ""),
                "line_number": ln_int,
                "quoted_line": (ql_m.group(1).strip("\n") if ql_m else ""),
                "raw": evid_raw if not (fp_m or ql_m) else "",
            }
            findings.append({
                "severity": sev.lower(),
                "category": cat.lower(),
                "claim": (claim_m.group(1) if claim_m else "").strip(),
                "evidence": evidence,
                "suggestion": (sugg_m.group(1) if sugg_m else "").strip(),
            })
        v_match = VERDICT_RE.search(block)
        if v_match:
            verdict = v_match.group(1).lower()
            verdict_reason = v_match.group(2).strip()
            verdict_reason = re.sub(r"<reasoning>(.*?)</reasoning>", r"\1", verdict_reason, flags=re.DOTALL).strip()

    return {
        "verdict": verdict,
        "verdict_reason": verdict_reason,
        "findings": findings,
        "done_marker": bool(DONE_RE.search(text)),
    }


def quorum_check(per_agent: dict, agent_types: dict[str, str], disabled: set[str] | None = None) -> dict:
    """
    Lineage-weighted quorum:
      need >=1 agent of each ENABLED lineage to return verdict=true.
      Lineages with all agents disabled are marked "disabled" and don't
      block the decision (degraded quorum -- user has explicitly opted out).
      verdict=partial counts as agree IFF the reviewer's findings list has no
      severity in {critical, high} (i.e. only nits).
    """
    disabled = disabled or set()
    # Derive lineages dynamically from agents.json types
    all_lineages = sorted(set(agent_types.values()))
    by_lineage = {lin: [] for lin in all_lineages}
    for agent_name, resp in per_agent.items():
        lin = agent_types.get(agent_name)
        if lin not in by_lineage:
            continue

        v = resp["verdict"]
        if v is None:
            continue

        if v == "true":
            agree = True
        elif v == "partial":
            blockers = [f for f in resp["findings"] if f["severity"] in ("critical", "high")]
            agree = not blockers
        else:
            agree = False

        by_lineage[lin].append({"agent": agent_name, "agree": agree, "verdict": v})

    lineage_status = {}
    for lin, agents in by_lineage.items():
        if lin in disabled:
            lineage_status[lin] = "disabled"
        elif not agents:
            lineage_status[lin] = "missing"
        elif any(a["agree"] for a in agents):
            lineage_status[lin] = "agree"
        else:
            lineage_status[lin] = "disagree"

    # Decision: disabled lineages don't block. Missing (active but no response)
    # -> incomplete. Disagree -> revise + retry.
    missing = [l for l, s in lineage_status.items() if s == "missing"]
    disagree = [l for l, s in lineage_status.items() if s == "disagree"]
    disabled_seen = [l for l, s in lineage_status.items() if s == "disabled"]

    if missing and not disagree:
        decision = "incomplete"
    elif not missing and not disagree:
        decision = "agree"
    else:
        decision = "disagree"

    return {
        "decision": decision,
        "by_lineage": by_lineage,
        "lineage_status": lineage_status,
        "missing_lineages": missing,
        "disagreeing_lineages": disagree,
        "disabled_lineages": disabled_seen,
    }


def main():
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--out-dir", required=True, help="dir containing <agent>-findings.md files")
    ap.add_argument("--agents", required=True, help="comma-separated list of agents that were nudged")
    ap.add_argument("--agents-json", default=str(Path.home() / ".config/agent-sessions/agents.json"))
    args = ap.parse_args()

    out_dir = Path(args.out_dir)
    agent_types = load_agent_types(Path(args.agents_json))
    expected = [a.strip() for a in args.agents.split(",") if a.strip()]

    per_agent = {}
    for name in expected:
        f = out_dir / f"{name}-findings.md"
        if not f.exists():
            per_agent[name] = {"verdict": None, "findings": [], "done_marker": False, "verdict_reason": "(no file)"}
            continue
        text = f.read_text(errors="replace")
        per_agent[name] = extract_response(text)

    # Self-consistency check: verify each finding's <quoted-line> appears in
    # the cited file. Findings whose quote can't be located are marked
    # `verified: false` -- likely hallucinations from over-eager review.
    # Repo root is best-effort: walk up from out_dir to find a .git dir, else cwd.
    def _find_repo_root(start: Path) -> Path:
        p = Path.cwd()
        for parent in [p, *p.parents]:
            if (parent / ".git").exists():
                return parent
        return p
    repo_root = _find_repo_root(out_dir)

    for name, resp in per_agent.items():
        for finding in resp["findings"]:
            ev = finding.get("evidence")
            if not isinstance(ev, dict):
                finding["verified"] = None  # legacy shape, can't verify
                continue
            ql = (ev.get("quoted_line") or "").strip()
            fp = (ev.get("file_path") or "").strip()
            if not ql or not fp:
                finding["verified"] = None  # not enough info to verify
                continue
            # Resolve path against repo root if relative
            target = Path(fp) if Path(fp).is_absolute() else (repo_root / fp)
            if not target.exists():
                finding["verified"] = False
                finding["verify_reason"] = f"file not found: {target}"
                continue
            try:
                source = target.read_text(errors="replace")
            except Exception as e:
                finding["verified"] = None
                finding["verify_reason"] = f"unreadable: {e}"
                continue
            # Compare with whitespace-tolerant match: collapse runs of WS to one space
            ql_norm = " ".join(ql.split())
            source_norm = " ".join(source.split())
            if ql_norm and ql_norm in source_norm:
                finding["verified"] = True
            else:
                finding["verified"] = False
                finding["verify_reason"] = "quoted-line not found in cited file"

    quorum = quorum_check(per_agent, agent_types, disabled_lineages(Path(args.agents_json)))

    # Aggregate finding stats -- distinguishes verified vs unverified
    all_findings = []
    for name, resp in per_agent.items():
        for f in resp["findings"]:
            all_findings.append({**f, "agent": name})

    sev_counts = {"critical": 0, "high": 0, "medium": 0, "low": 0}
    for f in all_findings:
        sev_counts[f["severity"]] = sev_counts.get(f["severity"], 0) + 1
    n_unverified = sum(1 for f in all_findings if f.get("verified") is False)
    n_verified = sum(1 for f in all_findings if f.get("verified") is True)

    output = {
        "decision": quorum["decision"],
        "lineage_status": quorum["lineage_status"],
        "missing_lineages": quorum["missing_lineages"],
        "disagreeing_lineages": quorum["disagreeing_lineages"],
        "per_agent": per_agent,
        "by_lineage": quorum["by_lineage"],
        "severity_counts": sev_counts,
        "total_findings": len(all_findings),
        "verified_findings": n_verified,
        "unverified_findings": n_unverified,
        "blockers": [f for f in all_findings if f["severity"] in ("critical", "high")],
        "unverified_blockers": [f for f in all_findings if f["severity"] in ("critical", "high") and f.get("verified") is False],
    }

    print(json.dumps(output, indent=2))

    sys.exit({"agree": 0, "disagree": 1, "incomplete": 2}[quorum["decision"]])


if __name__ == "__main__":
    main()
